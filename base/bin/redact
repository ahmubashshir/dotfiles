#!/bin/bash
# IMMEDIATES are core extensions.
# They may provide loader-facing helpers.
declare -a IMMEDIATES=('help' 'dump' 'sed')

# available rules contributors
# sort order is priority : GENERATORS
declare -a GENERATORS=('git' 'mail' 'hash' 'uuid' 'env')

# SHORT[shortopt]=mode maps short option to a mode
# shellcheck disable=SC2034
declare -A SHORT=()

# ARGSPEC: mode
# ? -> takes optional arg
# : -> takes mandatory arg
# @ -> is bool flag
# otherwise -> doesn't take args
# shellcheck disable=SC2034
declare -A ARGSPEC=()

# enabled redact modes
# shellcheck disable=SC2034
declare -Ai REDACT=()

# sed rules contributed by modes
declare -a RULES=()

declare -rAi RET=(
	['badsed']=1 # sed exit code
	['badfile']=2 #   ^^^
	['badio']=4 #   ^^^
	['generic']=3 # our exit code
	['badarg']=5 #   ^^^
	['badflag']=6 #   ^^^
	['module']=7 #   ^^^
)

message()
{
	local format="$1"
	shift
	printf 'redact%s: '"$format"'\n' "${TAG:+:$TAG}" "$@"
} >&2

error()
{
	local TAG="error${TAG:+:$TAG}"
	message "$@"
}

# escape / \ & (safe sed regexp | replacement)
quoteSed()
{
	case "$1" in
		p | pattern)
			sed 's/[/]/\\&/g'
			;;
		*) sed 's/[/&]/\\&/g' ;;
	esac
}

# escape ERE metacharacters for literal match
ERE2Literal()
{
	# shellcheck disable=SC2001
	# escape . * ^ + ? { } ( ) | $ \ [ ]
	sed 's/[.*^+?{}()|$\]\|\[\|\]/\\&/g' <<< "${1-$(<&0)}"
}

dSortStripPrio()
{
	sort -t: -nr | while IFS=: read -r _ line; do
		printf '%s\n' "$line"
	done
}

is-enabled()
{
	((REDACT["$1"] == 1))
}

set-enabled()
{
	((REDACT["$1"] == 0)) || return

	REDACT["$1"]=1
}

loadModules()
{
	local TAG
	local argtype elem
	local -a shortopts exports
	for mode in "${IMMEDIATES[@]}" "${GENERATORS[@]}"; do
		[[ -f "${BASH_SOURCE[0]%/*}/lib/redact/$mode.sh" ]] || {
			error 'Missing module: %s' "$mode"
			return 1
		}

		TAG="$mode"
		argtype='hidden'
		shortopts=()
		exports=()
		# shellcheck disable=SC1090
		source "${BASH_SOURCE[0]%/*}/lib/redact/$mode.sh"
		case "$argtype" in
			\? | optional) ARGSPEC["$mode"]='?' ;;
			: | required) ARGSPEC["$mode"]=':' ;;
			@ | boolean) ARGSPEC["$mode"]='@' ;;
			hidden) ;;
			*)
				error 'Invalid flag type: %s' "$argtype"
				return 1
				;;
		esac
		for elem in "${exports[@]}"; do
			[[ "$elem" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]] || {
				error 'Invalid global: %s' "$elem"
				return 1
			}

			declare -g "$elem"
		done

		[[ -n "${ARGSPEC["$mode"]}" ]] || continue
		for elem in "${shortopts[@]}"; do
			SHORT["$elem"]="$mode"
		done

	done > >(:) # leave only stderr open
} <&-

loadSedRules()
{
	local TAG
	for mode in "${GENERATORS[@]}"; do
		declare -F "addSedRules-$mode" > /dev/null || {
			error 'Bad module: %s' "$mode"
			return 1
		}

		TAG="$mode"
		"addSedRules-${mode}"
	done > >(:) # leave only stderr open
} <&-

# main segment
loadModules || exit "${RET['module']}"

args=()
while (($# > 0)); do
	arg="$1"
	shift
	case "$arg" in
		--) break ;; # stop processing args
		# handled by script
		@*) redactEnv "${arg#@}" || {
			error 'Invalid ENV name "%s"' "${arg#@}"
			exit "${RET['badarg']}"
		} ;;

		# offloaded flags
		--[^-]*=*)
			mode="${arg%%=*}"
			mode="${mode#--}"

			case "${ARGSPEC["$mode"]}" in
				@)
					error "%s doesn't accept arguments" "${arg%%=*}"
					exit "${RET['badarg']}"
					;;
				: | '?')
					if [[ -z "${arg#*=}" ]]; then
						error '%s needs an argument' "${arg%%=*}"
						exit "${RET['badarg']}"
					elif "enable-$mode" "${arg#*=}"; then
						continue
					else
						error 'invalid argument for %s: %s' "${arg%%=*}" "${arg#*=}"
						exit "${RET['badarg']}"
					fi
					;;
			esac

			error 'unknown option: %s' "${arg%%=*}"
			exit "${RET['badflag']}"
			;;

		--[^-]* | -[^-]*)
			case "$arg" in
				--*) mode="${arg#--}" ;;
				-*)
					arg="${arg#-}"
					[[ -z "${arg:1}" ]] || set -- "-${arg:1}" "$@"
					arg="${arg:0:1}"
					mode="${SHORT["$arg"]}"
					if [[ -z $mode ]]; then
						error 'unknown option: %s' "$arg"
						exit "${RET['badflag']}"
					fi
					;;
			esac

			case "${ARGSPEC["$mode"]}" in
				@)
					"enable-$mode"
					continue
					;;
				:)
					if [[ "$1" = "--" || -z "$1" ]]; then
						error '%s needs an argument' "$arg"
						exit "${RET['badarg']}"
					elif "enable-$mode" "$1"; then
						shift
					else
						error 'invalid argument for %s: %s' "$arg" "$1"
						exit "${RET['badarg']}"
					fi
					continue
					;;
				'?')
					case "$1" in
						-*) "enable-$mode" ;;
						*) ! "enable-$mode" "$1" || shift ;;
					esac
					continue
					;;
			esac

			error 'unknown option: %s' "$arg"
			exit "${RET['badflag']}"
			;;
		# rest
		*) args+=("$arg") ;;
	esac
done <&- > >(:) # leave only stderr open

if is-enabled show-help; then
	printHelp
fi

loadSedRules || exit "${RET['generic']}"
if is-enabled dump-rules; then
	printRules
else
	exec sed -uEf <(printf '%s\n' "${RULES[@]}") -- "${args[@]}"
fi
