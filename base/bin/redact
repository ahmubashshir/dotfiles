#!/bin/bash
# available rules contributors
# sort order is priority : IMMEDIATES > GENERATORS
declare -a GENERATORS=('git' 'mail' 'hash' 'uuid' 'env')
declare -a IMMEDIATES=('sed')

# SHORT[shortopt]=mode maps short option to a mode
# shellcheck disable=SC2034
declare -A SHORT=()

# ARGSPEC: mode
# ? -> takes optional arg
# : -> takes mandatory arg
# @ -> is bool flag
# otherwise -> doesn't take args
# shellcheck disable=SC2034
declare -A ARGSPEC=()

# enabled redact modes
# shellcheck disable=SC2034
declare -Ai REDACT=()

# sed rules contributed by modes
declare -a RULES=()

declare -rAi RET=(
	['badsed']=1 # sed exit code
	['badfile']=2 #   ^^^
	['badio']=4 #   ^^^
	['generic']=3 # our exit code
	['badarg']=5 #   ^^^
	['badflag']=6 #   ^^^
	['module']=7 #   ^^^
)

message()
{
	local format="$1"
	shift
	printf 'redact%s: '"$format"'\n' "${tag:+:$tag}" "$@" >&2
}

# escape / \ & (safe sed regexp | replacement)
quoteSed()
{
	case "$1" in
		p | pattern)
			sed 's/[/]/\\&/g'
			;;
		*) sed 's/[/&]/\\&/g' ;;
	esac
}

# escape ERE metacharacters for literal match
ERE2Literal()
{
	# shellcheck disable=SC2001
	# escape . * ^ + ? { } ( ) | $ \ [ ]
	sed 's/[.*^+?{}()|$\]\|\[\|\]/\\&/g' <<< "${1-$(<&0)}"
}

dSortStripLength()
{
	sort -t: -nr | while IFS=: read -r _ line; do
		printf '%s\n' "$line"
	done
}

loadModules()
{
	local tag
	for mode in "${IMMEDIATES[@]}" "${GENERATORS[@]}"; do
		[[ -f "${BASH_SOURCE[0]%/*}/lib/redact/$mode.sh" ]] || {
			tag=error
			message 'Missing module: %s' "$mode"
			return 1
		}

		tag="$mode"
		# shellcheck disable=SC1090
		source "${BASH_SOURCE[0]%/*}/lib/redact/$mode.sh"
	done
}

loadSedRules()
{
	for mode in "${GENERATORS[@]}"; do
		declare -F "addSedRules-$mode" > /dev/null || {
			tag=error
			message 'Bad module: %s' "$mode"
			return 1
		}

		tag="$mode"
		"addSedRules-${mode}"
	done
}

printHelp()
{
	cat >&2 << 'EOF'
Usage: redact [option]... @[ENV]... [--] [file]... < [file]... > output
Scrub local environment information from input stream

Options:
  -d, --dump
               dump generated replacement rules
EOF

	for mode in "${IMMEDIATES[@]}" "${GENERATORS[@]}"; do
		declare -F "helptext-$mode" > /dev/null || continue

		"helptext-$mode"
	done

	cat >&2 << 'EOF'
  -h, --help
               show this help text
EOF
	exit 0
}

# main segment
loadModules || exit "${RET['module']}"

args=()
while (($# > 0)); do
	arg="$1"
	shift
	case "$arg" in
		--) break ;; # stop processing args
		# handled by script
		@*) redactEnv "${arg#@}" || {
			message 'Invalid ENV name "%s"' "${arg#@}"
			exit "${RET['badarg']}"
		} ;;
		--help | -h) printHelp ;;
		--dump | -d) MODE='dump' ;;

		# offloaded flags
		--[^-]*=*)
			mode="${arg%%=*}"
			mode="${mode#--}"

			case "${ARGSPEC["$mode"]}" in
				@)
					message "%s doesn't accept arguments" "${arg%%=*}"
					exit "${RET['badarg']}"
					;;
				: | '?')
					if [[ -z "${arg#*=}" ]]; then
						message '%s needs an argument' "${arg%%=*}"
						exit "${RET['badarg']}"
					elif "enable-$mode" "${arg#*=}"; then
						continue
					else
						message 'invalid argument for %s: %s' "${arg%%=*}" "${arg#*=}"
						exit "${RET['badarg']}"
					fi
					;;
			esac

			message 'unknown option: %s' "${arg%%=*}"
			exit "${RET['badflag']}"
			;;

		--[^-]* | -[^-]*)
			case "$arg" in
				--*) mode="${arg#--}" ;;
				-*)
					mode="${SHORT["${arg#-}"]}"
					if [[ -z $mode ]]; then
						message 'unknown option: %s' "$arg"
						exit "${RET['badflag']}"
					fi
					;;
			esac

			case "${ARGSPEC["$mode"]}" in
				@)
					"enable-$mode"
					continue
					;;
				:)
					if [[ "$1" = "--" || -z "$1" ]]; then
						message '%s needs an argument' "$arg"
						exit "${RET['badarg']}"
					elif "enable-$mode" "$1"; then
						shift
					else
						message 'invalid argument for %s: %s' "$arg" "$1"
						exit "${RET['badarg']}"
					fi
					continue
					;;
				'?')
					! "enable-$mode" "$1" || shift
					continue
					;;
			esac

			message 'unknown option: %s' "$arg"
			exit "${RET['badflag']}"
			;;
		# rest
		*) args+=("$arg") ;;
	esac
done

loadSedRules || exit "${RET['generic']}"

if [[ "$MODE" == 'dump' ]]; then
	{
		printf '%%RULES {\n'
		printf '\t%s\n' "${RULES[@]}"
		printf '}\n\nsed -uEf %%RULES --'
		((${#args[@]} == 0)) || printf ' %Q' "${args[@]}"
		printf '\n'
	} >&2
else
	exec sed -uEf <(printf '%s\n' "${RULES[@]}") -- "${args[@]}"
fi
