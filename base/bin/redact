#!/bin/bash

declare -a MODES=('git' 'mail' 'hash' 'uuid' 'env')
# ARGSPEC: mode
# ? -> takes optional arg
# : -> takes mandatory arg
# @ -> is bool flag
# otherwise -> doesn't take args
# shellcheck disable=SC2034
declare -rA ARGSPEC=(
	['hash']='?'
	['git']='@'
	['mail']='@'
	['uuid']='@'
)

declare -Ai REDACT=()
declare -a RULES=()

# escape / \ & (safe sed regexp | replacement)
quoteSed()
{
	sed         's/[/&\\]/\\&/g'
}
# escape ERE metacharacters for literal match
ERE2Literal()
{
	# shellcheck disable=SC2001
	# escape . * ^ + ? { } ( ) | $ \ [ ]
	sed 's/[.*^+?{}()|$\]\|\[\|\]/\\&/g' <<< "${1-$(<&0)}"
}

loadModules()
{
	for mode in "${MODES[@]}"; do
		[[ -f "${BASH_SOURCE[0]%/*}/lib/redact/$mode.sh" ]] || {
			printf 'ERROR: Missing module: %s\n' "$mode" >&2
			return 1
		}

		# shellcheck disable=SC1090
		source "${BASH_SOURCE[0]%/*}/lib/redact/$mode.sh"
	done
}

loadSedRules()
{
	for mode in "${MODES[@]}"; do
		declare -F "addSedRules-$mode" > /dev/null || {
			printf 'ERROR: Bad module: %s\n' "$mode" >&2
			return 1
		}

		"addSedRules-${mode}"
	done
}

printHelp()
{
	cat >&2 << EOF
Usage: redact [option]... @[ENV]... [--] [file]... < [file]... > output
Scrub local environment information from input stream

Options:
  -e script, --expression script, --expression=script
               add the sed script to the filters
$(
		for mode in "${MODES[@]}"; do
			declare -F "helptext-$mode" > /dev/null || continue

			"helptext-${mode}"
		done
	)  -h, --help
               show this help text
EOF
	exit 0
}

loadModules || exit 1

envs=()
while (($# > 0)); do
	arg="$1"
	shift
	case "$arg" in
		--) break ;; # stop processing args
		# sed arg
		@*) envs+=("${arg#@}") ;;
		--expression=*) [[ -z "${arg#*=}" ]] || RULES+=("${arg#*=}") ;;
		-e | --expression)
			[[ "$1" && "$1" != "--" ]] || continue
			RULES+=("$1")
			shift
			;;
		# rest
		--git)
			((!REDACT['git'])) || continue
			set -- --mail "$@"
			REDACT['git']=1
			;;
		--mail)
			((!REDACT['mail'])) || continue
			REDACT['mail']=1
			;;
		--uuid)
			((!REDACT['uuid'])) || continue
			REDACT['uuid']=1
			;;
		--hash) enable-hash all ;;
		--hash=*) enable-hash "${arg#--hash=}" ;;
		--help | -h) printHelp ;;
		-*)
			printf 'redact: unknown option: %s\n' "$arg" >&2
			exit 2
			;;
	esac
done

loadSedRules || exit 1
exec sed -uEf <(printf '%s\n' "${RULES[@]}") -- "$@"
