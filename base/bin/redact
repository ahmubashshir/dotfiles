#!/bin/bash
# available rules contributors
# sorted by priority
declare -a GENERATORS=('sed' 'git' 'mail' 'hash' 'uuid' 'env')

# SHORT[shortopt]=mode maps short option to a mode
# shellcheck disable=SC2034
declare -A SHORT=()

# ARGSPEC: mode
# ? -> takes optional arg
# : -> takes mandatory arg
# @ -> is bool flag
# otherwise -> doesn't take args
# shellcheck disable=SC2034
declare -A ARGSPEC=()

# enabled redact modes
# shellcheck disable=SC2034
declare -Ai REDACT=()

# sed rules contributed by modes
declare -a RULES=()

declare -rAi RET=(
	['badsed']=1 # sed exit code
	['badfile']=2 #   ^^^
	['badio']=4 #   ^^^
	['generic']=3 # our exit code
	['badarg']=5 #   ^^^
	['badflag']=6 #   ^^^
	['module']=7 #   ^^^
)

# CORE modules are built-in components of redact itself.
# They provide initialization helpers, not redaction rules.
declare -ra CORE=('argparse' 'help' 'dump')

message()
{
	local format="$1"
	shift
	printf 'redact%s: '"$format"'\n' "${TAG:+:$TAG}" "$@"
} >&2

error()
{
	local TAG="error${TAG:+:$TAG}"
	message "$@"
}

# escape / \ & (safe sed regexp | replacement)
quoteSed()
{
	case "$1" in
		p | pattern)
			sed 's/[/]/\\&/g'
			;;
		*) sed 's/[/&]/\\&/g' ;;
	esac
}

# escape ERE metacharacters for literal match
ERE2Literal()
{
	# shellcheck disable=SC2001
	# escape . * ^ + ? { } ( ) | $ \ [ ]
	sed 's/[.*^+?{}()|$\]\|\[\|\]/\\&/g' <<< "${1-$(<&0)}"
}

dSortStripPrio()
{
	sort -t: -nr | while IFS=: read -r _ line; do
		printf '%s\n' "$line"
	done
}

is-enabled()
{
	((REDACT["$1"] == 1))
}

set-enabled()
{
	((REDACT["$1"] == 0)) || return

	REDACT["$1"]=1
}

sourceModule()
{
	local argtype=hidden TAG="$1" elem
	local -a shortopts=() exports=()
	[[ -f "${BASH_SOURCE[0]%/*}/lib/redact/$1.sh" ]] || {
		error 'Missing module: %s' "$1"
		return 1
	}

	# shellcheck disable=SC1090
	source "${BASH_SOURCE[0]%/*}/lib/redact/$1.sh"
	case "$argtype" in
		\? | optional) ARGSPEC["$1"]='?' ;;
		: | required) ARGSPEC["$1"]=':' ;;
		@ | boolean) ARGSPEC["$1"]='@' ;;
		hidden) ;;
		*)
			error 'Invalid flag type: %s' "$argtype"
			return 1
			;;
	esac
	for elem in "${exports[@]}"; do
		[[ "$elem" =~ ^[a-zA-Z_][a-zA-Z0-9_]*$ ]] || {
			error 'Invalid global: %s' "$elem"
			return 1
		}

		declare -g "$elem"
	done

	[[ -n "${ARGSPEC["$1"]}" ]] || return 0
	# shellcheck disable=SC2034
	for elem in "${shortopts[@]}"; do
		SHORT["$elem"]="$1"
	done
}

loadModules()
{
	local mod
	for mod in "${CORE[@]}"; do
		sourceModule "$mod" || return 1
	done > >(:) # leave only stderr open

	for mod in "${GENERATORS[@]}"; do
		sourceModule "$mod" || return 1
	done > >(:) # leave only stderr open
} <&-

loadSedRules()
{
	local TAG
	for mode in "${GENERATORS[@]}"; do
		declare -F "addSedRules-$mode" > /dev/null || {
			error 'Bad module: %s' "$mode"
			return 1
		}

		TAG="$mode"
		"addSedRules-${mode}"
	done > >(:) # leave only stderr open
} <&-

# main segment
loadModules || exit "${RET['module']}"

parseArgs "$@"

if is-enabled show-help; then
	printHelp
fi

loadSedRules || exit "${RET['generic']}"
if is-enabled dump-rules; then
	printRules
else
	# shellcheck disable=SC2154
	exec sed -uEf <(printf '%s\n' "${RULES[@]}") -- "${args[@]}"
fi
