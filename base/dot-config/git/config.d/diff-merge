[diff]
	guitool = meld
	colorMoved = default
[merge]
	guitool = meld
	tool = nano
	summary = true
	log = true
[mergetool "nano"]
	trustExitCode = false
	cmd = nano '+r/^=======$' $MERGED
[difftool]
	prompt = false
[mergetool]
	prompt = false

[pager]
    diff = delta
    log = delta
    reflog = delta
    show = delta
    blame = delta

[interactive]
    diffFilter = delta --color-only --features=interactive,terminal-theme

[delta]
    features = decorations terminal-theme
    line-numbers = true
    hyperlinks = true
    navigate = true
    detect-dark-light = never
    hyperlinks-file-link-format = "file://{path}?line={line}"
    syntax-theme = ansi
#    side-by-side = true

[delta "terminal-theme"]
    minus-style = red bold
    minus-emph-style = red strike bold
    plus-style  = green bold
    plus-emph-style = green ul bold

[delta "interactive"]
    keep-plus-minus-markers = false

[delta "decorations"]
    commit-decoration-style = blue ol
    commit-style = raw
    file-style = omit
    hunk-header-decoration-style = blue box
    hunk-header-file-style = red
    hunk-header-line-number-style = cyan
    hunk-header-style = file line-number syntax

[mergetool "meld"]
	useAutoMerge = true

