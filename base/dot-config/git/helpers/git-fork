#!/bin/bash
set -o pipefail
declare -iA hook
hook["github"]=1

#### Remotes Implementation Section ###
function identify_remote
{
	local url remote provider host

	url="$(git remote get-url "$1")"
	host="${url#*://}"
	host="${host#*@}"
	host="${host%%[:/]*}"

	case "$url" in
		*://*)
			remote="${url%%://*}://$host/"
			;;
		git@*:*)
			remote="git@${host}:"
			;;
		*)
			remote="unknown"
			;;
	esac

	case "$host" in
		github.com) provider=github ;;
		codeberg.org) provider=codeberg ;;
		gitlab.* | *.gitlab.*) provider=gitlab ;;
		*) provider=unknown ;;
	esac

	printf '%s %s %s\n' "$provider" "$host" "$remote"
}

# Codeberg
function codeberg_user
{
	AUTH=basic api_call codeberg.org/api/v1 user '.login'
}

function codeberg_fork
{
	local owner="$2" repo="$3" upstream="$4"

	json \
		:name "$repo" \
		:organization "$owner" \
		| AUTH=basic api_call codeberg.org/api/v1 "repos/$upstream/forks" '.' \
			-H 'Content-Type: application/json' \
			-X POST --data @- \
		| api_if_error
}

## GitHub
function github_user
{
	api_call api.github.com 'user' '.login' \
		-H "X-GitHub-Api-Version: 2026-03-10"
}

function github_fork
{
	local owner="$2" repo="$3" upstream="$4"

	json \
		:name "$repo" \
		:organization "$owner" \
		:default_branch_only :true \
		| api_call api.github.com "repos/$upstream/forks" . \
			-H "X-GitHub-Api-Version: 2026-03-10" \
			-H 'Content-Type: application/json' \
			-X POST --data @- \
		| api_if_error
}

function github_post
{
	while read -r key val; do
		case "$key:$val" in
			remote.upstream.gh-resolved:base) return ;;
			*:base) return ;;
		esac
	done < <(git config --get-regexp 'remote\..*\.gh-resolved')

	git config remote.upstream.gh-resolved base
}

## GitLab
function gitlab_user
{
	api_call "$1/api/v4" user .username
}

function gitlab_fork
{
	local domain="$1" owner="$2" repo="$3" upstream="$4"
	json \
		:name "$repo" \
		:namespace_path "$owner" \
		:mr_default_target_self :false \
		| api_call "$domain/api/v4" "projects/$(asuri "$upstream")/fork" . \
			-H 'Content-Type: application/json' \
			-X POST --data @- \
		| api_if_error || return 1

	gitlab_wait_import "$domain" "$owner/$repo"
}

function gitlab_wait_import
{
	local domain="$1" repo="$2" status
	while read -r status < <(
		api_call "$domain/api/v4" "projects/$(asuri "$repo")/import" .import_status
	); do
		case "$status" in
			'' | none | finished) break ;;
			scheduled | started) sleep 3 ;;
		esac
	done
}

### Script Utils Section ###
function require
{
	local missing=()

	for cmd in "$@"; do
		command -v "$cmd" > /dev/null 2>&1 || missing+=("$cmd")
	done

	if ((${#missing[@]})); then
		message '\e[31m\e[1m ! \e[0mMissing dependencies:'
		message '   - %s' "${missing[@]}"
		return 1
	fi
}

function message
{
	local template
	template="$1"
	shift
	# shellcheck disable=SC2059
	printf "$template\\n" "$@" >&2
}

function repo_exists
{
	git ls-remote -q "$1" HEAD 2> /dev/null 1>&2
}

function get_config
{
	git config --get "fork.$1.$2"
}

function repostrip
{
	sed -nE -e "s;$1;\1;g" -e 's;\.git$;;;p'
}

function creds
{
	printf 'protocol=https\nhost=%s\nusername=%s\n' "$1" "$2" \
		| git credential fill \
		| (
			declare -A creds
			while IFS='=' read -r key val; do
				creds["$key"]="$val"
			done
			printf '%s\0%s\0' "${creds["username"]}" "${creds["password"]}"
		)
}

function asuri
{
	jq -nc -r '$ARGS.positional[] | @uri' --args "$@"
}

function api_if_error
{
	jq -r $'if select(.message) then ("\e[31m ! \e[0m\(.message)\n" |halt_error(1)) else halt end'
}

function api_call
{
	local endpoint="$1" path="$2" jq="$3" user token config_user
	local -a auth
	shift 3

	read -r config_user < <(git config --get "credential.https://${endpoint%%/*}.username")
	mapfile -d '' -t auth < <(creds "${endpoint%%/*}" "$config_user")
	user="${auth[0]}"
	token="${auth[1]}"

	[[ "$token" ]] || return 1

	case "$AUTH" in
		basic)
			[[ -z "$user" ]] \
				|| set -- --expand-user '{{user}}:{{token}}' "$@"
			;;
		bearer | '')
			set -- --expand-oauth2-bearer '{{token}}' "$@"
			;;
	esac
	[[ -z "$AUTH" ]] || unset AUTH

	set -- --variable '%user' --variable '%token' "$@"

	user="$user" \
		token="$token" \
		curl --disable -s \
		--fail-with-body \
		"https://$endpoint/$path" "$@" \
		-H 'Accept: application/json' \
		| jq -r "$jq"
}

function get_arg
{
	local match arg
	match="$1"
	shift

	while (($# > 0)); do
		arg="$1"
		shift
		[[ $arg == "$match" ]] || continue
		[[ -n $1 && $1 != --* ]] || break
		echo "$1"
		return 0
	done
	return 1
}

function json
{
	local template
	local -a args
	template='{}'
	while (($# > 0)); do
		if [[ $1 == :* ]]; then
			if [[ $2 == :* ]]; then
				args+=(--argjson)
				template+=" + {${1#:}: \$${1#:}}"
			else
				args+=(--arg)
				template+=" + if (\$${1#:}|length) > 0 then {${1#:}: \$${1#:}} else {} end"
			fi
			args+=("${1#:}" "${2#:}")
			shift
		else
			args+=("$1")
		fi
		shift
	done

	: | jq -nc "$template" "${args[@]}"
}

function fork_setup
{
	local default
	read -r default < <(
		git symbolic-ref --short refs/remotes/upstream/HEAD \
			| cut -d/ -f2-
	)

	git config "branch.$default.remote" upstream
	git config "branch.$default.pushRemote" origin
	git config remote.pushDefault origin
	message '\e[32m\e[1m + \e[0mFork remotes configured...'
}

function create_fork
{
	local org repo user upstream
	local provider="$1" domain="$2" remote="$3"
	shift 3

	read -r user < <("${provider}_user" "$domain")
	read -r upstream < <(
		git remote get-url upstream \
			| repostrip '^.*[/:]([^/]+/[^/]+)$'
	)
	read -r repo < <(
		get_arg --name "$@" || git remote get-url upstream \
			| repostrip '^.*/([^/]+)$'
	)
	read -r org < <(
		get_arg --org "$@" || get_config "$domain" org
	)

	if [[ -z "$user" ]]; then
		message '\e[31m\e[1m ! \e[0mFailed to authenticate with \e[1m%s\e[0m...' "$domain"
		return 1
	fi

	if ! repo_exists "${remote}${org:-$user}/$repo"; then
		message '\e[32m\e[1m > \e[0mForking \e[1m%s\e[0m...' "$upstream"
		"${provider}_fork" "$domain" "${org:-$user}" "$repo" "$upstream" || return
		message '\e[32m\e[1m + \e[0mForked \e[1m%s\e[0m' "${org:-$user}/$repo"
	else
		message '\e[32m\e[1m + \e[0mFork exists \e[1m%s\e[0m' "${org:-$user}/$repo"
	fi

	case "$provider" in
		gitlab) repo+='.git' ;;
	esac

	if repo_exists "${remote}${org:-$user}/$repo"; then
		git remote add origin "${remote}${org:-$user}/$repo"
		message '\e[32m\e[1m + \e[0mRemote origin added...'
	fi

	if ((${hook["$provider"]})); then
		"${provider}_post" "$domain" "${org:-$user}" "$repo"
	fi
}

function rollback_failure
{
	trap ':' INT TERM QUIT EXIT
	if ! git remote | grep -xqw origin; then
		message '\e[31m\e[1m ! \e[0mFork failed, origin remote restored...'
		git remote rename upstream origin
		exit
	fi
	trap '-' INT TERM QUIT EXIT
}

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
	cat << 'EOF'
Usage: git fork [OPTIONS]

Fork the upstream remote into your account (or org) and set up origin + tracking.

OPTIONS
  --name <NAME>     Custom repository name for the fork (default: same as upstream)
  --org <ORG>       Fork under the given organization instead of your user account

  -h, --help        Show this help message

SUPPORTED PROVIDERS
  GitHub, GitLab, Codeberg

AUTHENTICATION
  Uses `git credential` (respects whatever helper you have configured:
  store, cache, manager, osxkeychain, etc.).

EXAMPLES
  $ git fork
  $ git fork --org myteam
  $ git fork --name my-cool-fork
EOF
	exit 0
fi

require git curl jq || exit 1
if ! git remote | grep -xqw upstream; then
	trap 'rollback_failure' INT TERM QUIT EXIT
	git remote rename origin upstream

	read -r provider domain remote < <(identify_remote upstream)
	if [[ $provider == unknown ]]; then
		message '\e[31m\e[1m ! \e[0mUnknown remote:\n\e[31m...\e[0m \e[1m%s\e[0m' "$(git remote get-url upstream)"
	else
		create_fork "$provider" "$domain" "$remote" "$@"
	fi

	rollback_failure
	fork_setup
else
	message '\e[33m\e[1m > \e[0mUpstream configured...'
	fork_setup
fi
